# ============================================
# golden-path-platform .gitignore
# Node / Python / K8s / Backstage / IDE
# ============================================

# ---- Node / Backstage ----
node_modules/
dist/
build/
.turbo/
*.tsbuildinfo
*.tgz
.yarn-integrity
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm
.eslintcache
*.env.local
.env.*.local

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
eggs/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/
*.whl

# ---- Kubernetes / Helm ----
charts/*/charts/
*.lock
*.swp

# ---- Terraform ----
.terraform/
*.tfstate
*.tfstate.*
.terraform.lock.hcl
*.tfvars
!*.tfvars.example
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ---- Docker ----
docker-compose.override.yml

# ---- IDE / Editor ----
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ---- OS ----
.DS_Store
Thumbs.db
desktop.ini
*.tmp
*.bak
*.orig

# ---- Secrets / Credentials (never commit) ----
*.pem
*.key
*.cert
*.p12
*.pfx
*.jks
secrets/
credentials/
kubeconfig*
.gcp-service-account.json
AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY

# ---- Backstage specifics ----
app/backstage/.env
app/backstage/.env.development.local
app/backstage/.env.production.local
app/backstage/.env.local

# ---- Logs ----
logs/
*.log

# ---- Misc ----
coverage/
.nyc_output/
tmp/
temp/
.cache/
