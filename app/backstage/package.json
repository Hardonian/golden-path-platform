{
  "name": "golden-path-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*",
      "plugins/*"
    ]
  },
  "scripts": {
    "dev": "concurrently \"yarn start\" \"yarn start-backend\"",
    "start": "yarn workspace app start",
    "start-backend": "yarn workspace backend start",
    "build": "tsc && yarn workspace app build && yarn workspace backend build",
    "build-image": "yarn workspace backend build-image",
    "tsc": "tsc",
    "tsc:full": "tsc --incremental false",
    "clean": "backstage-cli repo clean",
    "test": "backstage-cli repo test",
    "test:all": "backstage-cli repo test --coverage",
    "lint": "backstage-cli repo lint --fix",
    "lint:all": "backstage-cli repo lint",
    "prettier": "prettier --config .prettierrc --ignore-path .gitignore --ext \"*.ts,*.tsx,*.json,*.yaml\" .",
    "new": "backstage-cli new --scope @golden-path"
  },
  "dependencies": {
    "@backstage/backend-defaults": "^0.17.4",
    "@backstage/catalog-client": "^1.16.0",
    "@backstage/catalog-model": "^1.9.0",
    "@backstage/cli": "^0.36.3",
    "@backstage/config": "^1.3.8",
    "@backstage/dev-utils": "^1.1.24",
    "@backstage/plugin-auth-backend": "^0.29.1",
    "@backstage/plugin-catalog-backend": "^3.8.0",
    "@backstage/plugin-permission-backend": "^0.7.13",
    "@backstage/plugin-proxy-backend": "^0.6.14",
    "@backstage/plugin-scaffolder-backend": "^4.0.1",
    "@backstage/plugin-techdocs-backend": "^2.2.1",
    "@backstage/test-utils": "^1.7.19",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^26.1.0",
    "@types/react": "^19.0.0",
    "concurrently": "^9.1.2",
    "jest": "^29.7.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0"
  },
  "devDependencies": {
    "@backstage/cli": "^0.36.3",
    "prettier": "^3.5.3",
    "typescript": "~5.8.3"
  }
}
